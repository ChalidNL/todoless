FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY tsconfig*.json ./
COPY src/mcp ./src/mcp
RUN npm run mcp:build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production \
    TODOLESS_PB_URL=http://pocketbase:8090 \
    TODOLESS_MCP_TRANSPORT=stdio \
    TODOLESS_MCP_READONLY=true \
    TODOLESS_MCP_RATE_LIMIT=30 \
    TODOLESS_MCP_HTTP_PORT=3333
COPY package*.json ./
RUN npm ci --omit=dev && npm cache clean --force
COPY --from=builder /app/dist/mcp ./dist/mcp
USER node
EXPOSE 3333
CMD ["node", "dist/mcp/cli.js"]
