# ── todoless — one config for all environments ──
# Copy to .env and adjust values.

# Docker registry (default: ghcr.io/chalidnl)
REGISTRY=ghcr.io/chalidnl

# Image tag — the ONLY distinguishing factor between environments
#  latest = production (main branch)
#  pre    = release candidate (pre branch)
#  red    = design preview (red branch)
#  dev    = development (dev branch)
TODOLESS_TAG=latest

# Published port — freely choose any port (default: 7070)
TODOLESS_PORT=7070

# Timezone
TZ=Europe/Amsterdam

# Deployment environment label
DEPLOY_ENV=production

# Commit SHA (optional — set by CI)
COMMIT_SHA=unknown

# PocketBase data directory on host (default: /DATA/AppData/todoless)
# Each environment SHOULD use a separate directory to avoid data conflicts.
PB_DATA_DIR=/DATA/AppData/todoless

# ── Sensitive config (NEVER commit real values) ──
# Keep values empty in this template.
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=
ENCRYPTION_KEY=
API_TOKEN=

# Paperless-ngx integration
PAPERLESS_URL=
PAPERLESS_API_KEY=
PAPERLESS_WEBHOOK_SECRET=

# Optional integrations
SENTRY_DSN=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
